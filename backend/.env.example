# Copy this to .env and fill in real values
# NEVER commit .env to git

# Database
POSTGRES_PASSWORD=changeme_local

# Redis
REDIS_PASSWORD=changeme_local

# Clerk Auth — get from clerk.com dashboard > API Keys
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN.clerk.accounts.dev/.well-known/jwks.json

# Sentry — get from sentry.io dashboard
SENTRY_DSN=https://REPLACE_ME@o123456.ingest.sentry.io/REPLACE_ME

# Resend — get from resend.com dashboard
RESEND_API_KEY=re_REPLACE_ME

# App
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
